LLM_MODE=local

# LM Studio server URL (default port)
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Model selection for LM Studio
# Heavy model: Logic, Security, Orchestrator agents (complex reasoning)
# Light model: Syntax, Git History agents (pattern matching)
# Using Qwen3.6 27B Q4_K_M GGUF (matches LM Studio API identifier)
LMSTUDIO_HEAVY_MODEL=qwen2.5-coder-14b-instruct-mlx
LMSTUDIO_LIGHT_MODEL=qwen2.5-coder-14b-instruct-mlx

# Context window size (32K - optimal for code review with Qwen3.6)
LMSTUDIO_CONTEXT_SIZE=32768

# Minimum severity to report: low, medium, high, critical
SEVERITY_THRESHOLD=medium
