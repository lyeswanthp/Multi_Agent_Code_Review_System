# Mode: "local" (LM Studio, no API keys needed) or "remote" (cloud APIs)
LLM_MODE=local

# LM Studio settings (local mode)
# Start the local server in LM Studio: Developer tab → Start Server (default port 1234)
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Set these to the exact model identifier shown in LM Studio's model dropdown
# (e.g. "qwen2.5-coder-14b-instruct", "mistral-7b-instruct-v0.3", etc.)
LMSTUDIO_HEAVY_MODEL=qwen2.5-coder-14b-instruct
LMSTUDIO_LIGHT_MODEL=mistral-7b-instruct-v0.3

# Remote API keys (only needed when LLM_MODE=remote)
NVIDIA_API_KEY=nvapi-...
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=csk-...

# Severity threshold (low, medium, high, critical)
SEVERITY_THRESHOLD=medium
